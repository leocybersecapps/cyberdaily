<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="Content-Security-Policy" content="default-src 'none'; style-src 'unsafe-inline'; base-uri 'none'; form-action 'none'; frame-ancestors 'none'">
  <meta name="description" content="Top 5 notícias de cybersecurity do dia — curadoria com ângulo executivo.">
  <title>CyberDaily · {{ data_formatada }}</title>
  <style>
    :root {
      --bg: #0c0c10;
      --bg-card: #14141a;
      --text: #e4e4e7;
      --text-dim: #a1a1aa;
      --border: #27272a;
      --accent: #22d3ee;
      --accent-soft: rgba(34, 211, 238, 0.08);
    }

    @media (prefers-color-scheme: light) {
      :root {
        --bg: #fafaf9;
        --bg-card: #ffffff;
        --text: #18181b;
        --text-dim: #52525b;
        --border: #e4e4e7;
        --accent: #0891b2;
        --accent-soft: rgba(8, 145, 178, 0.08);
      }
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    html { font-size: 16px; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
      line-height: 1.6;
      padding: 2rem 1rem 3rem;
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
    }

    main,
    .page-header,
    .site-footer {
      max-width: 760px;
      margin-left: auto;
      margin-right: auto;
    }

    .page-header {
      padding-bottom: 1.75rem;
      margin-bottom: 2rem;
      border-bottom: 1px solid var(--border);
    }

    .page-header h1 {
      font-size: 2rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .page-header h1::before {
      content: "▌";
      color: var(--accent);
    }

    .subtitle {
      color: var(--text-dim);
      font-size: 0.9rem;
      margin-top: 0.5rem;
      font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
    }

    .card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1.75rem;
      margin-bottom: 1.25rem;
      position: relative;
    }

    .rank {
      position: absolute;
      top: 1.25rem;
      right: 1.25rem;
      font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
      font-size: 0.8rem;
      color: var(--text-dim);
      background: var(--bg);
      padding: 0.2rem 0.55rem;
      border-radius: 4px;
      border: 1px solid var(--border);
    }

    .card h2 {
      font-size: 1.3rem;
      font-weight: 600;
      line-height: 1.3;
      margin-bottom: 0.75rem;
      padding-right: 3rem;
      letter-spacing: -0.01em;
    }

    .summary {
      color: var(--text-dim);
      margin-bottom: 1rem;
    }

    .why {
      font-size: 0.95rem;
      margin-bottom: 1rem;
    }

    .why-label {
      color: var(--accent);
      font-weight: 600;
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      display: block;
      margin-bottom: 0.25rem;
      font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
    }

    .hook {
      border-left: 3px solid var(--accent);
      padding: 0.85rem 1rem;
      margin: 1rem 0 1.25rem;
      font-style: italic;
      background: var(--accent-soft);
      border-radius: 0 4px 4px 0;
    }

    .meta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      align-items: center;
      padding-top: 1rem;
      border-top: 1px solid var(--border);
      font-size: 0.85rem;
      color: var(--text-dim);
      font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
    }

    .meta a {
      color: var(--accent);
      text-decoration: none;
    }

    .meta a:hover,
    .meta a:focus-visible {
      text-decoration: underline;
    }

    .meta .sep {
      color: var(--border);
    }

    .empty {
      text-align: center;
      color: var(--text-dim);
      padding: 3rem 1rem;
      border: 1px dashed var(--border);
      border-radius: 8px;
    }

    .site-footer {
      margin-top: 3rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--border);
      color: var(--text-dim);
      font-size: 0.8rem;
      text-align: center;
      font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
    }

    @media (max-width: 600px) {
      body { padding: 1.25rem 0.75rem 2rem; }
      .card { padding: 1.25rem; }
      .page-header h1 { font-size: 1.55rem; }
      .card h2 { font-size: 1.15rem; }
      .rank { top: 1rem; right: 1rem; }
    }
  </style>
</head>
<body>
  <header class="page-header">
    <h1>CyberDaily</h1>
    <p class="subtitle">Top 5 · {{ data_formatada }}</p>
  </header>

  <main>
    {% if articles %}
      {% for article in articles %}
      <article class="card">
        <span class="rank">#{{ loop.index }}</span>
        <h2>{{ article.titulo }}</h2>
        <p class="summary">{{ article.resumo }}</p>
        <div class="why">
          <span class="why-label">Por que importa</span>
          {{ article.por_que_importa }}
        </div>
        <blockquote class="hook">{{ article.gancho_conversa }}</blockquote>
        <footer class="meta">
          <a href="{{ article.url }}" rel="noopener noreferrer" target="_blank">{{ article.fonte }}</a>
          <span class="sep">·</span>
          <span class="date">{{ (article.data_publicacao | to_brt).strftime('%d/%m/%Y') }}</span>
        </footer>
      </article>
      {% endfor %}
    {% else %}
      <p class="empty">Sem notícias disponíveis hoje.</p>
    {% endif %}
  </main>

  <footer class="site-footer">
    <p>Gerado automaticamente em {{ gerado_em }}</p>
  </footer>
</body>
</html>
