<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <meta http-equiv="Content-Security-Policy" content="default-src 'none'; style-src 'unsafe-inline'; base-uri 'none'; form-action 'none'; frame-ancestors 'none'">
  <meta name="description" content="Curadoria diária de cybersecurity + IA com ângulo executivo.">
  <title>CyberDaily · {{ data_formatada }}</title>
  <style>
    :root {
      --bg: #0c0c10;
      --bg-card: #14141a;
      --text: #e4e4e7;
      --text-dim: #a1a1aa;
      --border: #27272a;
      --accent: #22d3ee;
      --accent-soft: rgba(34, 211, 238, 0.08);
      --accent-ai: #a78bfa;
      --accent-ai-soft: rgba(167, 139, 250, 0.08);
    }

    @media (prefers-color-scheme: light) {
      :root {
        --bg: #fafaf9;
        --bg-card: #ffffff;
        --text: #18181b;
        --text-dim: #52525b;
        --border: #e4e4e7;
        --accent: #0891b2;
        --accent-soft: rgba(8, 145, 178, 0.08);
        --accent-ai: #7c3aed;
        --accent-ai-soft: rgba(124, 58, 237, 0.08);
      }
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    html { font-size: 16px; }

    body {
      background: var(--bg);
      color: var(--text);
      font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, "Helvetica Neue", Arial, sans-serif;
      line-height: 1.6;
      padding: 2rem 1rem 3rem;
      min-height: 100vh;
      -webkit-font-smoothing: antialiased;
    }

    main,
    .page-header,
    .site-footer {
      max-width: 760px;
      margin-left: auto;
      margin-right: auto;
    }

    .page-header {
      padding-bottom: 1.75rem;
      margin-bottom: 2rem;
      border-bottom: 1px solid var(--border);
    }

    .page-header h1 {
      font-size: 2rem;
      font-weight: 700;
      letter-spacing: -0.02em;
      display: flex;
      align-items: center;
      gap: 0.5rem;
    }

    .page-header h1::before {
      content: "▌";
      color: var(--accent);
    }

    .subtitle {
      color: var(--text-dim);
      font-size: 0.9rem;
      margin-top: 0.5rem;
      font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
    }

    .section {
      margin-bottom: 2.5rem;
    }

    .section-header {
      display: flex;
      align-items: baseline;
      gap: 0.6rem;
      margin-bottom: 1.25rem;
      padding-bottom: 0.5rem;
      border-bottom: 1px solid var(--border);
    }

    .section-header h2 {
      font-size: 1rem;
      font-weight: 600;
      letter-spacing: 0.06em;
      text-transform: uppercase;
      font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
      color: var(--accent);
    }

    .section-ai .section-header h2 {
      color: var(--accent-ai);
    }

    .section-header .section-count {
      color: var(--text-dim);
      font-size: 0.8rem;
      font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
    }

    .card {
      background: var(--bg-card);
      border: 1px solid var(--border);
      border-radius: 8px;
      padding: 1.75rem;
      margin-bottom: 1.25rem;
      position: relative;
    }

    .rank {
      position: absolute;
      top: 1.25rem;
      right: 1.25rem;
      font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
      font-size: 0.8rem;
      color: var(--text-dim);
      background: var(--bg);
      padding: 0.2rem 0.55rem;
      border-radius: 4px;
      border: 1px solid var(--border);
    }

    .card h3 {
      font-size: 1.3rem;
      font-weight: 600;
      line-height: 1.3;
      margin-bottom: 0.75rem;
      padding-right: 3rem;
      letter-spacing: -0.01em;
    }

    .summary {
      color: var(--text-dim);
      margin-bottom: 1rem;
    }

    .why {
      font-size: 0.95rem;
      margin-bottom: 1rem;
    }

    .why-label {
      color: var(--accent);
      font-weight: 600;
      font-size: 0.78rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      display: block;
      margin-bottom: 0.25rem;
      font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
    }

    .section-ai .why-label {
      color: var(--accent-ai);
    }

    .hooks {
      display: flex;
      flex-direction: column;
      gap: 0.6rem;
      margin: 1rem 0 1.25rem;
    }

    .hook {
      border-left: 3px solid var(--accent);
      padding: 0.85rem 1rem;
      font-style: italic;
      background: var(--accent-soft);
      border-radius: 0 4px 4px 0;
    }

    .hook-label {
      display: block;
      font-style: normal;
      font-weight: 600;
      font-size: 0.7rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      color: var(--accent);
      margin-bottom: 0.3rem;
      font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
    }

    .hook-biz {
      border-left-color: var(--text-dim);
      background: transparent;
      border: 1px dashed var(--border);
      border-left-width: 3px;
    }

    .hook-biz .hook-label {
      color: var(--text-dim);
    }

    .section-ai .hook {
      border-left-color: var(--accent-ai);
      background: var(--accent-ai-soft);
    }

    .section-ai .hook .hook-label {
      color: var(--accent-ai);
    }

    .section-ai .hook-biz {
      border-left-color: var(--text-dim);
      background: transparent;
      border: 1px dashed var(--border);
      border-left-width: 3px;
    }

    .section-ai .hook-biz .hook-label {
      color: var(--text-dim);
    }

    .meta {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      align-items: center;
      padding-top: 1rem;
      border-top: 1px solid var(--border);
      font-size: 0.85rem;
      color: var(--text-dim);
      font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
    }

    .meta a {
      color: var(--accent);
      text-decoration: none;
    }

    .section-ai .meta a {
      color: var(--accent-ai);
    }

    .meta a:hover,
    .meta a:focus-visible {
      text-decoration: underline;
    }

    .meta .sep {
      color: var(--border);
    }

    .empty {
      text-align: center;
      color: var(--text-dim);
      padding: 2rem 1rem;
      border: 1px dashed var(--border);
      border-radius: 8px;
      font-size: 0.9rem;
    }

    .site-footer {
      margin-top: 3rem;
      padding-top: 1.5rem;
      border-top: 1px solid var(--border);
      color: var(--text-dim);
      font-size: 0.8rem;
      text-align: center;
      font-family: ui-monospace, "SF Mono", Menlo, Consolas, monospace;
    }

    @media (max-width: 600px) {
      body { padding: 1.25rem 0.75rem 2rem; }
      .card { padding: 1.25rem; }
      .page-header h1 { font-size: 1.55rem; }
      .card h3 { font-size: 1.15rem; }
      .rank { top: 1rem; right: 1rem; }
    }
  </style>
</head>
<body>
  <header class="page-header">
    <h1>CyberDaily</h1>
    <p class="subtitle">Cyber + IA · {{ data_formatada }}</p>
  </header>

  <main>
    <section class="section section-cyber" aria-labelledby="sec-cyber">
      <div class="section-header">
        <h2 id="sec-cyber">Top Cyber</h2>
        {% if articles_cyber %}
        <span class="section-count">{{ articles_cyber | length }} hoje</span>
        {% endif %}
      </div>
      {% if articles_cyber %}
        {% for article in articles_cyber %}
        <article class="card">
          <span class="rank">#{{ loop.index }}</span>
          <h3>{{ article.titulo }}</h3>
          <p class="summary">{{ article.resumo }}</p>
          <div class="why">
            <span class="why-label">Por que importa</span>
            {{ article.por_que_importa }}
          </div>
          <div class="hooks">
            <blockquote class="hook">
              <span class="hook-label">Leitura técnica</span>
              {{ article.gancho_conversa }}
            </blockquote>
            <blockquote class="hook hook-biz">
              <span class="hook-label">Leitura comercial</span>
              {{ article.leitura_comercial }}
            </blockquote>
          </div>
          <footer class="meta">
            <a href="{{ article.url }}" rel="noopener noreferrer" target="_blank">{{ article.fonte }}</a>
            <span class="sep">·</span>
            <span class="date">{{ (article.data_publicacao | to_brt).strftime('%d/%m/%Y') }}</span>
          </footer>
        </article>
        {% endfor %}
      {% else %}
        <p class="empty">Sem curadoria de cyber hoje.</p>
      {% endif %}
    </section>

    <section class="section section-ai" aria-labelledby="sec-ai">
      <div class="section-header">
        <h2 id="sec-ai">IA &amp; Tech</h2>
        {% if articles_ai %}
        <span class="section-count">{{ articles_ai | length }} hoje</span>
        {% endif %}
      </div>
      {% if articles_ai %}
        {% for article in articles_ai %}
        <article class="card">
          <span class="rank">#{{ loop.index }}</span>
          <h3>{{ article.titulo }}</h3>
          <p class="summary">{{ article.resumo }}</p>
          <div class="why">
            <span class="why-label">Por que importa</span>
            {{ article.por_que_importa }}
          </div>
          <div class="hooks">
            <blockquote class="hook">
              <span class="hook-label">Leitura técnica</span>
              {{ article.gancho_conversa }}
            </blockquote>
            <blockquote class="hook hook-biz">
              <span class="hook-label">Leitura comercial</span>
              {{ article.leitura_comercial }}
            </blockquote>
          </div>
          <footer class="meta">
            <a href="{{ article.url }}" rel="noopener noreferrer" target="_blank">{{ article.fonte }}</a>
            <span class="sep">·</span>
            <span class="date">{{ (article.data_publicacao | to_brt).strftime('%d/%m/%Y') }}</span>
          </footer>
        </article>
        {% endfor %}
      {% else %}
        <p class="empty">Sem curadoria de IA hoje.</p>
      {% endif %}
    </section>
  </main>

  <footer class="site-footer">
    <p>Gerado automaticamente em {{ gerado_em }}</p>
  </footer>
</body>
</html>
